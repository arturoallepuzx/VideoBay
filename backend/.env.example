APP_NAME=VideoBay
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:4200

AUTH_JWT_SECRET=
AUTH_ACCESS_TTL_SECONDS=900
AUTH_REFRESH_TTL_SECONDS=2592000
AUTH_MAX_CONCURRENT_SESSIONS=2

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Admin inicial (seeder)
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_NAME=

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Docker (compose): usa MySQL del servicio db
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=videobay
DB_USERNAME=
DB_PASSWORD=

# Solo para inicialización del contenedor MySQL
MYSQL_ROOT_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
REDIS_TRANSCODING_QUEUE=transcoding
REDIS_TRANSCODING_RETRY_AFTER=86500
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@videobay.dev"
MAIL_FROM_NAME="${APP_NAME}"

# Storage de archivos del proyecto
VIDEO_STORAGE_PATH=/var/lib/videobay/videos
SUBTITLE_STORAGE_PATH=/var/lib/videobay/subtitles
AVATAR_STORAGE_PATH=/var/lib/videobay/avatars

# Streaming
STREAM_URL=http://localhost:8000
STREAMING_KEEP_ORIGINAL_AFTER_PROCESSING=false
STREAMING_CLEANUP_FAILED_AFTER_DAYS=3

# FFmpeg
FFMPEG_BINARY=/usr/bin/ffmpeg
FFMPEG_THREADS=2
FFMPEG_PRESET=slow
FFMPEG_CRF=18

# TMDB — https://www.themoviedb.org/settings/api (usar API Read Access Token v4, NO la API key v3)
TMDB_READ_ACCESS_TOKEN=
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
TMDB_DEFAULT_LANGUAGE=es-ES
TMDB_SEARCH_CACHE_TTL=3600
TMDB_DETAIL_CACHE_TTL=86400
TMDB_RECOMMENDATIONS_CACHE_TTL=604800
TMDB_PERSON_CACHE_TTL=86400

# OpenSubtitles — https://www.opensubtitles.com/es/consumers
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=
OPENSUBTITLES_BASE_URL=https://api.opensubtitles.com/api/v1
OPENSUBTITLES_USER_AGENT="VideoBay"

# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Barcode lookup — UPCDatabase (https://upcdatabase.org/api)
BARCODE_API_KEY=
BARCODE_BASE_URL=https://api.upcdatabase.org

# Inventory
INVENTORY_CURRENCY=EUR

# Order
ORDER_CHECKOUT_TTL_MINUTES=30

# Wishlist
WISHLIST_PINNED_MAX_SLOTS=5

VITE_APP_NAME="${APP_NAME}"
